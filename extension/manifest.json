{
  "manifest_version": 3,
  "name": "AlteredHistory",
  "version": "0.1.0",
  "description": "Sync your Altered game history from Board Game Arena",
  "host_permissions": [
    "https://boardgamearena.com/*",
    "https://*.boardgamearena.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
